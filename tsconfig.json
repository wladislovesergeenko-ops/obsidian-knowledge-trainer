{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "lib": ["DOM", "ES2018"],
    "moduleResolution": "node",
    "allowJs": true,
    "noImplicitAny": true,
    "outDir": "./dist",
    "sourceMap": true,
    "baseUrl": ".",
    "inlineSources": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strict": true,
    "jsx": "react",
    "jsxFactory": "h",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
